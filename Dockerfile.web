# Japatext web — Vite SPA for Railway.
# In Railway: Settings → Build → Dockerfile path = Dockerfile.web
# Set VITE_API_BASE_URL at build time (e.g. https://japatext-server-production.up.railway.app/api).

FROM node:22-bookworm-slim AS build

WORKDIR /app

COPY package.json package-lock.json ./
COPY server/package.json server/package.json
COPY web/package.json web/package.json

RUN npm ci --workspace web

COPY web web/

ARG VITE_API_BASE_URL=https://japatext-server-production.up.railway.app/api
ENV VITE_API_BASE_URL=$VITE_API_BASE_URL

RUN npm run build --workspace web

FROM node:22-bookworm-slim

WORKDIR /app

RUN npm install -g serve@14

COPY --from=build /app/web/dist ./dist

ENV NODE_ENV=production
ENV PORT=3000

EXPOSE 3000

CMD ["sh", "-c", "serve -s dist -l tcp://0.0.0.0:${PORT}"]

OPENAI_API_KEY=sk-your-key-here
PORT=8787
JAPATEXT_GENERATION_MODEL=gpt-5-mini
JAPATEXT_TAGGING_MODEL=gpt-5.4-nano
JAPATEXT_MAX_REQUESTS_PER_DAY=400

# Optional — enable invite-only multi-user auth. Leave blank for local SQLite mode.
# Use the same Project URL and publishable (anon) key as the web app.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Production CORS — comma-separated frontend origins (Vercel URL).
# WEB_ORIGIN=https://japatext.vercel.app

# Persistent SQLite directory on Railway/Fly (mount a volume at /data).
# JAPATEXT_DATA_DIR=/data

# Invite-only auth on shared SQLite (abuse gate). Requires service role + invites table.
# JAPATEXT_SINGLE_TENANT_AUTH=1

# Full multi-user Postgres (not wired yet):
# JAPATEXT_DATABASE=postgres

# Optional — multi-user auth (Vite uses VITE_*, not Next.js NEXT_PUBLIC_*).
# Supabase dashboard → Project Settings → API: use the Project URL and
# publishable (anon) key.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Production only — full URL to the deployed Express API (include /api suffix).
# Leave unset in local dev (Vite proxies /api to localhost:8787).
VITE_API_BASE_URL=

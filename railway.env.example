# Copy these into Railway → your service → Variables (personal / mode A deploy).
# Do NOT paste this file into Railway — fill values in the dashboard only.

NODE_ENV=production
OPENAI_API_KEY=
JAPATEXT_DATA_DIR=/data
WEB_ORIGIN=

# Optional — only after Vercel is live, set to your frontend URL, e.g.:
# WEB_ORIGIN=https://japatext.vercel.app
# For local testing against prod API, comma-separate:
# WEB_ORIGIN=https://japatext.vercel.app,http://localhost:5173

# Leave ALL of these unset on Railway for mode A (personal SQLite deploy):
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
